{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['nick', 'avatarId'])",
        "nick": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 24"
        },
        "avatarId": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40"
        },
        "photoUrl": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 2048 && newData.val().beginsWith('https://'))"
        },
        "email": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 254)"
        },
        "displayName": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)"
        },
        "createdAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "updatedAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "predictions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "scores": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
