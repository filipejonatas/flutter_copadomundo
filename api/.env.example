PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://127.0.0.1:4200,http://localhost:4200
FIREBASE_PROJECT_ID=copa-palpite
FIREBASE_DATABASE_URL=https://copa-palpite-default-rtdb.firebaseio.com
FIREBASE_APP_CHECK_REQUIRED=true
FIREBASE_APP_CHECK_CONSUME_TOKENS=false
FIREBASE_AUTH_CHECK_REVOKED=false
# Use uma destas opcoes no deploy:
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64_do_json_da_service_account
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# Ou configure credenciais padrao do ambiente, como GOOGLE_APPLICATION_CREDENTIALS.
WC2026_BASE_URL=https://api.wc2026api.com
WC2026_API_KEY=coloque_sua_chave_wc2026_aqui
PREDICTION_CUTOFF_BUFFER_SECONDS=60
PREDICTION_IP_RATE_LIMIT=60
PREDICTION_USER_RATE_LIMIT=20
PREDICTION_FIXTURE_RATE_LIMIT=5
PREDICTION_RATE_WINDOW_SECONDS=60
PREDICTION_FIXTURE_RATE_WINDOW_SECONDS=10
